# ============================================================
# NIA - .gitignore
# Proyecto: NIA / VIA Industrial
# Objetivo:
# - evitar subir credenciales
# - evitar subir datos pesados
# - evitar archivos temporales y logs
# - mantener el repositorio limpio
# ============================================================


# ============================================================
# VARIABLES DE ENTORNO / SECRETOS
# ============================================================
.env
.env.*
!.env.example


# ============================================================
# ENTORNO PYTHON
# ============================================================
venv/
.venv/
ENV/
env/

__pycache__/
*.py[cod]
*$py.class


# ============================================================
# LOGS
# ============================================================
logs/
*.log


# ============================================================
# DATOS PESADOS / ETL
# ============================================================
productos_limpio.json
productos.json
nia_base_limpia*
test_conexion_sql.py
productos-289496 con Score para Nia.xlsx

*.csv
*.xls
*.xlsx
*.zip
*.7z
*.rar

# Dumps / backups
*.bak
*.dump
*.sql


# ============================================================
# JUPYTER / NOTEBOOKS
# ============================================================
.ipynb_checkpoints/
*.ipynb
salidas_nia_logs/

# ============================================================
# ARCHIVOS TEMPORALES
# ============================================================
*.tmp
*.temp
*.cache


# ============================================================
# VISUAL STUDIO CODE / IDEs
# ============================================================
.vscode/
.idea/


# ============================================================
# SISTEMA OPERATIVO
# ============================================================
.DS_Store
Thumbs.db
desktop.ini


# ============================================================
# PYTEST / COVERAGE
# ============================================================
.pytest_cache/
.coverage
htmlcov/


# ============================================================
# MONGO / BASES DE DATOS LOCALES
# ============================================================
*.wt
*.bson


# ============================================================
# NODE / FRONTEND (por si luego agregan frontend moderno)
# ============================================================
node_modules/
dist/
build/
uploads/

# ============================================================
# AZURE / DEPLOY
# ============================================================
.azure/